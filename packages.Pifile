# Install the necessary packages
RUN apt-get update --allow-releaseinfo-change && apt-get install -y --fix-missing \
    python-is-python3 \
    python3-pip \
    python3-virtualenv \
    git \
    gh \
    i2c-tools \
    python3-smbus \
    python3-spidev \
    libopenblas-dev \
    libatlas-base-dev \
    wireless-tools
